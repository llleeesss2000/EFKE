# User Web UI
USER_WEB_HOST=0.0.0.0
USER_WEB_PORT=6161

# Server API
# 如果 Server 在同一台電腦，保持 127.0.0.1
# 如果 Server 在另一台電腦，改成該電腦的 IP 位址
# 也可以在瀏覽器設定精靈中修改
SERVER_API_URL=http://127.0.0.1:8000

# LLM Provider
# 如果 LLM 在 Server 端，改成 Server 的 IP 位址
LLM_PROVIDER=ollama
LLM_BASE_URL=http://127.0.0.1:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=

# Embedding Provider
EMBEDDING_PROVIDER=server
EMBEDDING_MODEL=

# Quantized Data Location
# 可選：server / user
QUANTIZED_DATA_LOCATION=server

# 若選 user，量化資料存在 User 端此目錄
USER_DATA_DIR=./user_data

# Auth
DEFAULT_USERNAME=admin
DEFAULT_PASSWORD=12345

# Language
UI_LANGUAGE=zh-TW
